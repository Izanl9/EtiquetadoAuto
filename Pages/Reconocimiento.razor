@code {
    public class InfoLinea 
    {
        public string Texto { get; set; } = "";
        public int Y { get; set; }
    }

    private List<Producto> productosDetectados = new();
    private bool isProcessing = false;
    private string estadoMensaje = "Procesando...";

    private async Task CapturarAlbaran()
    {
        try
        {
            isProcessing = true;
            estadoMensaje = "Abriendo cámara...";
            StateHasChanged(); 

            var photo = await MediaPicker.CapturePhotoAsync();
            if (photo == null) return;

            estadoMensaje = "Analizando imagen...";
            StateHasChanged(); 

            #if ANDROID
            var javaFile = new Java.IO.File(photo.FullPath);
            var imageUri = Android.Net.Uri.FromFile(javaFile);
            var image = Xamarin.Google.MLKit.Vision.Common.InputImage.FromFilePath(Android.App.Application.Context, imageUri);
            
            var options = Xamarin.Google.MLKit.Vision.Text.Latin.TextRecognizerOptions.DefaultOptions;
            var recognizer = Xamarin.Google.MLKit.Vision.Text.TextRecognition.GetClient(options);
            
            var tcs = new TaskCompletionSource<object>();
            
            recognizer.Process(image)
                .AddOnSuccessListener(new OnSuccessImplementation(tcs))
                .AddOnFailureListener(new OnFailureImplementation(tcs));

            var resultObj = await tcs.Task;
            var visionText = (Xamarin.Google.MLKit.Vision.Text.Text)resultObj;
            
            ProcesarTextoEspacial(visionText);
            #else
            await JSRuntime.InvokeVoidAsync("alert", "OCR solo disponible en Android.");
            #endif
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error: " + ex.Message);
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    #if ANDROID
    private void ProcesarTextoEspacial(Xamarin.Google.MLKit.Vision.Text.Text visionText)
    {
        productosDetectados.Clear();
        var todasLasLineas = new List<InfoLinea>();

        foreach (var block in visionText.TextBlocks)
        {
            foreach (var line in block.Lines)
            {
                todasLasLineas.Add(new InfoLinea { 
                    Texto = line.Text.Trim(), 
                    Y = line.BoundingBox.CenterY() 
                });
            }
        }

        if (!todasLasLineas.Any()) return;

        var lineasOrdenadas = todasLasLineas.OrderBy(l => l.Y).ToList();
        var filas = new List<List<InfoLinea>>();
        var filaActual = new List<InfoLinea> { lineasOrdenadas[0] };

        for (int i = 1; i < lineasOrdenadas.Count; i++)
        {
            if (Math.Abs(lineasOrdenadas[i].Y - lineasOrdenadas[i-1].Y) < 25)
            {
                filaActual.Add(lineasOrdenadas[i]);
            }
            else
            {
                filas.Add(new List<List<InfoLinea>>(new[] { filaActual }).First());
                filas.Add(new List<InfoLinea>(filaActual));
                filas.RemoveAt(filas.Count - 2); // Limpieza de lógica de duplicados
                filaActual = new List<InfoLinea> { lineasOrdenadas[i] };
            }
        }
        filas.Add(filaActual);

        foreach (var fila in filas)
        {
            string textoFilaUnido = string.Join(" ", fila.Select(f => f.Texto));
            
            // Normalizamos texto para filtros (sin acentos, minúsculas)
            string minus = textoFilaUnido.ToLower()
                .Replace("à", "a").Replace("è", "e").Replace("é", "e")
                .Replace("í", "i").Replace("ò", "o").Replace("ó", "o").Replace("ú", "u");

            // --- FILTRO DE CABECERAS Y DATOS DE EMPRESA ---
            // IMPORTANTE: Hemos quitado "serie" para que detecte productos que contengan esa palabra
            if (minus.Contains("albara") || minus.Contains("comanda") || 
                minus.Contains("nom i cognom") || minus.Contains("telefon") || minus.Contains("telf") ||
                minus.Contains("direccio") || minus.Contains("carrer") || minus.Contains("fecha") || 
                minus.Contains("data") || minus.Contains("quantitat") || minus.Contains("descripci") || 
                minus.Contains("www.") || minus.Contains("@") || minus.Contains("edit.org") ||
                minus.Contains("sintesi") || minus.Contains("fictici"))
            {
                continue;
            }

            // Filtro para números largos (teléfonos o series de albarán)
            string sinEspacios = textoFilaUnido.Replace(" ", "");
            if (System.Text.RegularExpressions.Regex.IsMatch(sinEspacios, "\\d{8,}")) continue;

            int cantidadEncontrada = 0;
            string nombreProducto = "";

            foreach (var item in fila)
            {
                // Detectar cantidad (1-3 dígitos)
                if (System.Text.RegularExpressions.Regex.IsMatch(item.Texto.Trim(), "^\\d{1,3}$"))
                {
                    cantidadEncontrada = int.Parse(item.Texto.Trim());
                }
                else if (item.Texto.Length > 3)
                {
                    // Limpiar caracteres pero mantener nombres de producto complejos
                    string limpio = System.Text.RegularExpressions.Regex.Replace(item.Texto, "[^a-zA-Z0-9áéíóúÁÉÍÓÚñÑ\\s\\.\\-®]", "").Trim();
                    if (!string.IsNullOrEmpty(limpio))
                    {
                        nombreProducto += (string.IsNullOrEmpty(nombreProducto) ? "" : " ") + limpio;
                    }
                }
            }

            // Validación: nombre con longitud mínima para ser considerado producto
            if (!string.IsNullOrWhiteSpace(nombreProducto) && nombreProducto.Length > 6)
            {
                productosDetectados.Add(new Producto {
                    Nombre = nombreProducto,
                    Cantidad = cantidadEncontrada > 0 ? cantidadEncontrada : 1,
                    Codigo = "OCR-" + DateTime.Now.ToString("mmss")
                });
            }
        }
    }
    #endif

    private async Task ProcesarTodo()
    {
        try
        {
            isProcessing = true;
            estadoMensaje = "Guardando...";
            StateHasChanged();

            foreach (var prod in productosDetectados)
            {
                await DB.GuardarProducto(prod);
            }

            string ruta = GeneradorPdf.GenerarEtiquetas(productosDetectados);
            await Launcher.Default.OpenAsync(new OpenFileRequest {
                Title = "Etiquetas",
                File = new ReadOnlyFile(ruta)
            });

            LimpiarEscaneo();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error: " + ex.Message);
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private void LimpiarEscaneo() => productosDetectados.Clear();

#if ANDROID
    public class OnSuccessImplementation : Java.Lang.Object, Android.Gms.Tasks.IOnSuccessListener
    {
        private readonly TaskCompletionSource<object> _tcs;
        public OnSuccessImplementation(TaskCompletionSource<object> tcs) => _tcs = tcs;
        public void OnSuccess(Java.Lang.Object result) => _tcs.SetResult(result);
    }


    public class OnFailureImplementation : Java.Lang.Object, Android.Gms.Tasks.IOnFailureListener
    {
        private readonly TaskCompletionSource<object> _tcs;
        public OnFailureImplementation(TaskCompletionSource<object> tcs) => _tcs = tcs;
        public void OnFailure(Java.Lang.Exception e) => _tcs.SetException(e);
    }
#endif
