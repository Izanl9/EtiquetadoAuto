@page "/reconocimiento"
@using EtiquetadoAuto.Models
@using Microsoft.Maui.Media
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white text-center">
            <h4><i class="oi oi-camera"></i> Reconocimiento de Albarán</h4>
        </div>
        <div class="card-body text-center">
            <p class="text-muted">Captura una foto del albarán para detectar automáticamente los productos y cantidades.</p>
            
            @if (isProcessing)
            {
                <div class="my-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">Procesando imagen con OCR...</p>
                </div>
            }
            else
            {
                <button class="btn btn-lg btn-success w-100 mb-3" @onclick="CapturarAlbaran">
                    <i class="oi oi-camera"></i> Tomar Foto
                </button>
            }

            @if (productosDetectados.Any())
            {
                <hr />
                <h5 class="text-start">Productos Detectados:</h5>
                <ul class="list-group">
                    @foreach (var prod in productosDetectados)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            @prod.Nombre
                            <span class="badge bg-primary rounded-pill">x @prod.Cantidad</span>
                        </li>
                    }
                </ul>
                <button class="btn btn-primary mt-3 w-100" @onclick="ConfirmarCarga">
                    Confirmar e Importar al Inventario
                </button>
            }
        </div>
    </div>
</div>

@code {
    private List<Producto> productosDetectados = new();
    private bool isProcessing = false;

    private async Task CapturarAlbaran()
    {
        try
        {
            if (!MediaPicker.Default.IsSupported)
            {
                await JSRuntime.InvokeVoidAsync("alert", "La cámara no está disponible en este dispositivo.");
                return;
            }

            var photo = await MediaPicker.Default.CapturePhotoAsync();
            if (photo == null) return;

            isProcessing = true;
            StateHasChanged();

            // Guardamos la ruta para depuración
            var localPath = photo.FullPath;

            // --- LÓGICA DE OCR (COMENTADA TEMPORALMENTE PARA COMPILACIÓN) ---
            /*
            #if ANDROID
            var imageUri = Android.Net.Uri.FromFile(new Java.IO.File(localPath));
            var image = Xamarin.GooglePlayServices.MLKit.Vision.Common.InputImage.FromFilePath(Android.App.Application.Context, imageUri);
            var recognizer = Xamarin.GooglePlayServices.MLKit.Vision.Text.TextRecognition.GetClient(Xamarin.GooglePlayServices.MLKit.Vision.Text.Latin.TextRecognizerOptions.DefaultOptions);
            
            var result = await recognizer.Process(image);
            string textoExtraido = result.GetText();
            ProcesarTexto(textoExtraido);
            #endif
            */

            // Simulación para que la interfaz muestre algo mientras arreglamos el paquete NuGet
            productosDetectados.Clear();
            productosDetectados.Add(new Producto { Nombre = "Caja Tornillos M8", Cantidad = 5, Codigo = "T-001" });
            productosDetectados.Add(new Producto { Nombre = "Arandelas Acero", Cantidad = 10, Codigo = "A-050" });

            await JSRuntime.InvokeVoidAsync("alert", "Foto capturada correctamente. (OCR en modo simulación)");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error: " + ex.Message);
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private void ProcesarTexto(string texto)
    {
        // Esta lógica se activará cuando reinstalemos el paquete OCR
        productosDetectados.Clear();
        var lineas = texto.Split('\n');
        foreach (var linea in lineas)
        {
            // Lógica de filtrado de texto...
        }
    }

    private async Task ConfirmarCarga()
    {
        // Aquí llamarías a tu StockService para guardar los productos
        await JSRuntime.InvokeVoidAsync("alert", "Productos importados al inventario con éxito.");
        productosDetectados.Clear();
    }
}