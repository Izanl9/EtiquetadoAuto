@page "/reconocimiento"
@using EtiquetadoAuto.Models
@using EtiquetadoAuto.Services
@using Microsoft.Maui.Media

@inject StockService StockService
@inject IJSRuntime JSRuntime

<div class="container">
    <h3>Escáner de Albaranes</h3>
    
    <button class="btn btn-primary w-100 mb-3" @onclick="CapturarYProcesar">
        <i class="oi oi-camera"></i> Escanear Albarán Real
    </button>

    @if (isProcessing)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Analizando texto del albarán...</p>
        </div>
    }

    @if (productosDetectados.Any())
    {
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-success text-white">Detectado por OCR</div>
            <ul class="list-group list-group-flush">
                @foreach (var p in productosDetectados)
                {
                    <li class="list-group-item d-flex justify-content-between">
                        @p.Nombre <span>x@p.Cantidad</span>
                    </li>
                }
            </ul>
        </div>
        <button class="btn btn-danger w-100" @onclick="GenerarPdfEtiquetas">Generar Etiquetas</button>
    }
</div>

@code {
    private List<Producto> productosDetectados = new();
    private bool isProcessing = false;
   
    #if ANDROID
        using TextRecognition = Xamarin.GooglePlayServices.MLKit.Vision.Text;
        using VisionCommon = Xamarin.GooglePlayServices.MLKit.Vision.Common;
    #endif
    private async Task CapturarYProcesar()
    {
        try 
        {
            var photo = await MediaPicker.Default.CapturePhotoAsync();
            if (photo == null) return;

            isProcessing = true;
            StateHasChanged();

            string textoExtraido = "";

#if ANDROID
            // LÓGICA NATIVA DE GOOGLE ML KIT
            var imageUri = Android.Net.Uri.FromFile(new Java.IO.File(photo.FullPath));
            var image = Xamarin.GooglePlayServices.MLKit.Vision.Common.InputImage.FromFilePath(Android.App.Application.Context, imageUri);
            var recognizer = Xamarin.GooglePlayServices.MLKit.Vision.Text.TextRecognition.GetClient(Xamarin.GooglePlayServices.MLKit.Vision.Text.Latin.TextRecognizerOptions.DefaultOptions);
            
            var result = await recognizer.Process(image);
            textoExtraido = result.GetText();
#else
            textoExtraido = "Simulación: Producto A 10 unidades"; 
#endif

            // Procesar el texto extraído para buscar cantidades y nombres
            ParsearTextoAlbaran(textoExtraido);
            
            if (productosDetectados.Any())
                await StockService.ActualizarDesdeAlbaran(productosDetectados);
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error OCR: " + ex.Message);
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private void ParsearTextoAlbaran(string texto)
    {
        productosDetectados.Clear();
        // Lógica simple: Buscar líneas que contengan números (cantidades)
        var lineas = texto.Split('\n');
        foreach (var linea in lineas)
        {
            // Ejemplo: Si la línea tiene un número, asumimos que es cantidad
            var match = System.Text.RegularExpressions.Regex.Match(linea, @"(\d+)");
            if (match.Success)
            {
                int cant = int.Parse(match.Value);
                string nombre = linea.Replace(match.Value, "").Trim();
                if (!string.IsNullOrEmpty(nombre))
                {
                    productosDetectados.Add(new Producto { Nombre = nombre, Cantidad = cant });
                }
            }
        }
    }

    private async Task GenerarPdfEtiquetas() { /* Tu lógica de PDF aquí */ }
}