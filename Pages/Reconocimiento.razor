@page "/reconocimiento"
@using EtiquetadoAuto.Models
@using Microsoft.Maui.Media
@using Microsoft.JSInterop
@using Xamarin.Google.MLKit.Vision.Common
@using Xamarin.Google.MLKit.Vision.Text
@inject IJSRuntime JSRuntime

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white text-center">
            <h4><i class="oi oi-camera"></i> Reconocimiento de Albarán</h4>
        </div>
        <div class="card-body text-center">
            <p class="text-muted">Captura una foto del albarán para detectar automáticamente los productos y cantidades.</p>
            
            @if (isProcessing)
            {
                <div class="my-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">Procesando imagen...</p>
                </div>
            }
            else
            {
                <button class="btn btn-lg btn-success w-100 mb-3" @onclick="CapturarAlbaran">
                    <i class="oi oi-camera"></i> Tomar Foto
                </button>
            }

            @if (productosDetectados.Any())
            {
                <hr />
                <h5 class="text-start">Productos Detectados:</h5>
                <ul class="list-group">
                    @foreach (var prod in productosDetectados)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            @prod.Nombre
                            <span class="badge bg-primary rounded-pill">x @prod.Cantidad</span>
                        </li>
                    }
                </ul>
                <button class="btn btn-primary mt-3 w-100" @onclick="ConfirmarCarga">
                    Confirmar e Importar al Inventario
                </button>
            }
        </div>
    </div>
</div>

@code {
    private List<Producto> productosDetectados = new();
    private bool isProcessing = false;

    private async Task CapturarAlbaran()
    {
        try
        {
            if (MediaPicker.Default == null) return;

            var photo = await MediaPicker.Default.CapturePhotoAsync();
            if (photo == null) return;

            isProcessing = true;
            StateHasChanged();

            string textoDetectado = "";

            #if ANDROID
            // Código real de OCR para Android con rutas completas para evitar errores CS0103
            var javaFile = new Java.IO.File(photo.FullPath);
            var imageUri = Android.Net.Uri.FromFile(javaFile);
            
            // 1. Cargamos la imagen
            var image = Xamarin.Google.MLKit.Vision.Common.InputImage.FromFilePath(Android.App.Application.Context, imageUri);
            
            // 2. Configuramos el reconocedor (usamos el Latin por defecto)
            var options = Xamarin.Google.MLKit.Vision.Text.Latin.TextRecognizerOptions.DefaultOptions;
            var recognizer = Xamarin.Google.MLKit.Vision.Text.TextRecognition.GetClient(options);
            
            // 3. Procesamos la imagen
            var result = await recognizer.Process(image);
            
            // 4. Extraemos el texto del resultado
            var visionText = (Xamarin.Google.MLKit.Vision.Text.Text)result;
            textoDetectado = visionText.Text;
            #endif

            ProcesarTexto(textoDetectado);
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error en el escaneo: " + ex.Message);
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private void ProcesarTexto(string texto)
    {
        productosDetectados.Clear();
        var lineas = texto.Split('\n');
        foreach (var linea in lineas)
        {
            var match = System.Text.RegularExpressions.Regex.Match(linea, @"(\d+)");
            if (match.Success)
            {
                productosDetectados.Add(new Producto { 
                    Nombre = linea.Replace(match.Value, "").Trim(), 
                    Cantidad = int.Parse(match.Value),
                    Codigo = "OCR-" + Guid.NewGuid().ToString().Substring(0,4)
                });
            }
        }
    }

    private async Task ConfirmarCarga()
    {
        await JSRuntime.InvokeVoidAsync("alert", "Importación completada.");
        productosDetectados.Clear();
    }
}