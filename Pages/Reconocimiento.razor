@page "/reconocimiento"
@using EtiquetadoAuto.Models
@using EtiquetadoAuto.Services
@using Microsoft.Maui.Media
@using Microsoft.JSInterop
@using System.Threading.Tasks
@inject IJSRuntime JSRuntime
@inject DatabaseService DB
@inject PdfService GeneradorPdf

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white text-center">
            <h4 class="mb-0"><i class="oi oi-camera"></i> Reconocimiento de Albarán</h4>
        </div>
        <div class="card-body text-center">
            <p class="text-muted">Captura una foto del albarán para detectar automáticamente los productos.</p>
            
            @if (isProcessing)
            {
                <div class="my-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">@estadoMensaje</p>
                </div>
            }
            else
            {
                <button class="btn btn-lg btn-success w-100 mb-3 shadow" @onclick="CapturarAlbaran">
                    <i class="oi oi-camera"></i> TOMAR FOTO
                </button>
            }

            @if (productosDetectados.Any())
            {
                <hr />
                <h5 class="text-start mb-3">Productos Identificados:</h5>
                <ul class="list-group mb-3 shadow-sm">
                    @foreach (var prod in productosDetectados)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div class="text-start">
                                <strong>@prod.Nombre</strong><br />
                                <small class="text-muted">Ref: @prod.Codigo</small>
                            </div>
                            <span class="badge bg-primary rounded-pill fs-6">x @prod.Cantidad</span>
                        </li>
                    }
                </ul>

                <div class="d-grid gap-2">
                    <button class="btn btn-lg btn-primary shadow" @onclick="ProcesarTodo">
                        <i class="oi oi-print"></i> IMPRIMIR Y GUARDAR
                    </button>
                    <button class="btn btn-outline-danger btn-sm" @onclick="LimpiarEscaneo">
                        Cancelar y Borrar
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<Producto> productosDetectados = new();
    private bool isProcessing = false;
    private string estadoMensaje = "Procesando...";

    private async Task CapturarAlbaran()
    {
        try
        {
            isProcessing = true;
            estadoMensaje = "Abriendo cámara...";
            StateHasChanged(); 

            var photo = await MediaPicker.CapturePhotoAsync();
            if (photo == null) return;

            estadoMensaje = "Analizando texto con IA...";
            StateHasChanged(); 

            #if ANDROID
            var javaFile = new Java.IO.File(photo.FullPath);
            var imageUri = Android.Net.Uri.FromFile(javaFile);
            var image = Xamarin.Google.MLKit.Vision.Common.InputImage.FromFilePath(Android.App.Application.Context, imageUri);
            
            var options = Xamarin.Google.MLKit.Vision.Text.Latin.TextRecognizerOptions.DefaultOptions;
            var recognizer = Xamarin.Google.MLKit.Vision.Text.TextRecognition.GetClient(options);
            
            // Usamos object para que Razor no se confunda con los tags HTML
            var tcs = new TaskCompletionSource<object>();
            
            recognizer.Process(image)
                .AddOnSuccessListener(new OnSuccessImplementation(tcs))
                .AddOnFailureListener(new OnFailureImplementation(tcs));

            var resultObj = await tcs.Task;
            var visionText = (Xamarin.Google.MLKit.Vision.Text.Text)resultObj;
            string textoDetectado = visionText.GetText();
            
            if (string.IsNullOrWhiteSpace(textoDetectado))
            {
                await JSRuntime.InvokeVoidAsync("alert", "No se detectó texto.");
            }
            else
            {
                ExtraerProductosDelTexto(textoDetectado);
            }
            #else
            await JSRuntime.InvokeVoidAsync("alert", "El OCR requiere un dispositivo Android.");
            #endif
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private void ExtraerProductosDelTexto(string texto)
    {
        var lineas = texto.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);
        productosDetectados.Clear();

        List<int> cantidades = new List<int>();
        List<string> nombres = new List<string>();

        string[] palabrasProhibidas = { 
            "albara", "albard", "sintse", "sintesis", "cognom", "telefon", "telfon", 
            "direccio", "carrer", "carer", "fecha", "quantitat", "descripci", 
            "comanda", "serie", "srie", "edit", "www", "nmero" 
        };

        foreach (var linea in lineas)
        {
            string limpia = linea.Trim();
            if (string.IsNullOrWhiteSpace(limpia)) continue;

            string minusculas = limpia.ToLower().Replace("á", "a").Replace("é", "e").Replace("í", "i").Replace("ó", "o").Replace("ú", "u");

            bool esBasura = false;
            foreach (var prohibida in palabrasProhibidas)
            {
                if (minusculas.Contains(prohibida))
                {
                    esBasura = true;
                    break;
                }
            }
            if (esBasura) continue; 

            // Columna de cantidades
            string posibleNumero = limpia.Replace(" ", "");
            if (int.TryParse(posibleNumero, out int numeroSuelto))
            {
                if (numeroSuelto > 0 && numeroSuelto < 10000)
                {
                    cantidades.Add(numeroSuelto);
                }
                continue;
            }

            // Ojo: Sin la arroba en los strings de Regex
            var matchCombinado = System.Text.RegularExpressions.Regex.Match(limpia, "^(\\d+)\\s+(.+)");
            if (matchCombinado.Success)
            {
                int cant = int.Parse(matchCombinado.Groups[1].Value);
                if (cant > 0 && cant < 10000) cantidades.Add(cant);
                
                string nombreExtraido = matchCombinado.Groups[2].Value;
                string nombreLimpio = System.Text.RegularExpressions.Regex.Replace(nombreExtraido, "[^a-zA-ZáéíóúÁÉÍÓÚñÑ0-9\\s\\.\\-®]", "").Trim();
                if (nombreLimpio.Length > 4) nombres.Add(nombreLimpio);
                
                continue;
            }

            // Columna de descripciones (Sin arroba, barras dobles)
            string soloTexto = System.Text.RegularExpressions.Regex.Replace(limpia, "[^a-zA-ZáéíóúÁÉÍÓÚñÑ0-9\\s\\.\\-®]", "").Trim();
            if (soloTexto.Length > 4)
            {
                // Filtro para ignorar fechas
                if (!System.Text.RegularExpressions.Regex.IsMatch(limpia, "\\d{2}[/-]\\d{2}[/-]\\d{2,4}"))
                {
                    nombres.Add(soloTexto);
                }
            }
        }

        // Emparejamiento Final (Zipping)
        for (int i = 0; i < nombres.Count; i++)
        {
            int cantAsignada = 1; 
            
            if (i < cantidades.Count)
            {
                cantAsignada = cantidades[i];
            }
            
            productosDetectados.Add(new Producto {
                Nombre = nombres[i],
                Cantidad = cantAsignada,
                Codigo = "OCR-" + DateTime.Now.ToString("mmss")
            });
        }
    }

    private async Task ProcesarTodo()
    {
        try
        {
            isProcessing = true;
            estadoMensaje = "Guardando e imprimiendo...";
            StateHasChanged();

            foreach (var prod in productosDetectados)
            {
                await DB.GuardarProducto(prod);
            }

            string rutaArchivo = GeneradorPdf.GenerarEtiquetas(productosDetectados);
            
            await Launcher.Default.OpenAsync(new OpenFileRequest
            {
                Title = "Etiquetas de Albarán",
                File = new ReadOnlyFile(rutaArchivo)
            });

            LimpiarEscaneo();
            await JSRuntime.InvokeVoidAsync("alert", "Inventario actualizado y etiquetas generadas.");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error al procesar: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private void LimpiarEscaneo()
    {
        productosDetectados.Clear();
    }

#if ANDROID
    public class OnSuccessImplementation : Java.Lang.Object, Android.Gms.Tasks.IOnSuccessListener
    {
        private readonly TaskCompletionSource<object> _tcs;
        public OnSuccessImplementation(TaskCompletionSource<object> tcs) => _tcs = tcs;
        public void OnSuccess(Java.Lang.Object result) => _tcs.SetResult(result);
    }

    public class OnFailureImplementation : Java.Lang.Object, Android.Gms.Tasks.IOnFailureListener
    {
        private readonly TaskCompletionSource<object> _tcs;
        public OnFailureImplementation(TaskCompletionSource<object> tcs) => _tcs = tcs;
        public void OnFailure(Java.Lang.Exception e) => _tcs.SetException(e);
    }
#endif
}