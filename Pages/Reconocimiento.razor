@page "/reconocimiento"
@using Microsoft.Maui.Media
@using EtiquetadoAuto.Models
@inject IJSRuntime JSRuntime

<div class="container text-center">
    <h3>Escáner de Productos</h3>
    <hr />

    <div class="d-grid gap-2">
        <button class="btn btn-primary btn-lg" @onclick="TomarFoto">
            <i class="oi oi-camera"></i> Abrir Cámara
        </button>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert alert-info mt-3">
            @statusMessage
        </div>
    }
</div>

@code {
    private string statusMessage = "Listo para escanear";

    private async Task TomarFoto()
    {
        try
        {
            if (MediaPicker.Default.IsCaptureSupported)
            {
                statusMessage = "Abriendo cámara...";
                StateHasChanged(); // Actualiza el mensaje en pantalla

                FileResult photo = await MediaPicker.Default.CapturePhotoAsync();
                
                if (photo != null)
                {
                    statusMessage = "Foto recibida. Analizando...";
                    StateHasChanged(); // Actualiza para que el usuario vea el cambio

                    // SIMULACIÓN DE PROCESADO
                    await Task.Delay(2000); 
                    
                    statusMessage = "Producto reconocido: Objeto de prueba";
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
            StateHasChanged();
        }
    }
}