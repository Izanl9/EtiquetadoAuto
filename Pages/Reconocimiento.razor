@page "/reconocimiento"
@namespace EtiquetadoAuto.Pages
@using System.IO
@inject IJSRuntime JS

<div class="container-fluid text-center mt-4">
    <h3 class="text-primary mb-4"> Visión Artificial Móvil</h3>
    <p class="text-muted">Usa la cámara del móvil para identificar la mercancía.</p>

    <button class="btn btn-primary btn-lg w-100 shadow fw-bold mb-3" @onclick="TomarFotoNativa">
        📷 ABRIR CÁMARA
    </button>

    @if (!string.IsNullOrEmpty(FotoBase64))
    {
        <img src="@FotoBase64" class="img-fluid rounded shadow-sm mb-3" style="max-height: 300px; object-fit: contain;" />
        
        <button class="btn btn-success btn-lg w-100 fw-bold" @onclick="AnalizarConIA" disabled="@Analizando">
            ANALIZAR PRODUCTO
        </button>
    }

    @if (Analizando)
    {
        <div class="mt-4">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="fw-bold mt-2">Analizando imagen...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(ProductoDetectado))
    {
        <div class="alert alert-success mt-4 shadow-sm">
            <h4> ¡Producto Reconocido!</h4>
            <h2 class="fw-bold text-dark">@ProductoDetectado</h2>
            
            <div class="mt-4">
                <label class="form-label fw-bold">¿Cuántas unidades entran?</label>
                <input type="number" class="form-control form-control-lg text-center mb-3 fw-bold" @bind="CantidadEntrante" min="1" />
                
                <button class="btn btn-warning btn-lg w-100 fw-bold shadow" @onclick="RegistrarEImprimir">
                    AÑADIR E IMPRIMIR
                </button>
            </div>
        </div>
    }
</div>

@code {
    string FotoBase64 = "";
    bool Analizando = false;
    string ProductoDetectado = "";
    int CantidadEntrante = 1;

    // PON AQUÍ TU ENLACE REAL DE TEACHABLE MACHINE
    string UrlModeloGoogle = " https://teachablemachine.withgoogle.com/models/_0smO1zii/";

    protected override async Task OnInitializedAsync()
    {
        // Cargamos la IA al abrir la pantalla
        await JS.InvokeVoidAsync("cargarModelo", UrlModeloGoogle);
    }

    Task TomarFoto()
{
    try 
    {
        var status = await Permissions.CheckStatusAsync<Permissions.Camera>();
        if (status != PermissionStatus.Granted)
            status = await Permissions.RequestAsync<Permissions.Camera>();

        if (status == PermissionStatus.Granted)
        {
            // Aquí va tu código actual de abrir la cámara
        }
    }
    catch (Exception ex)
    {
        // Esto evitará el cierre repentino y te dirá qué pasa
        Console.WriteLine($"Error: {ex.Message}");
    }
}

    async Task AnalizarConIA()
    {
        Analizando = true;
        ProductoDetectado = "";
        StateHasChanged();

        // Llamamos al JavaScript para analizar la foto que acabamos de hacer
        ProductoDetectado = await JS.InvokeAsync<string>("predecirImagen", FotoBase64);
        
        Analizando = false;
        StateHasChanged();
    }

    void RegistrarEImprimir()
    {
        Console.WriteLine($"Añadidas {CantidadEntrante} unidades de '{ProductoDetectado}'.");
        ProductoDetectado = ""; 
        FotoBase64 = "";
    }
}
