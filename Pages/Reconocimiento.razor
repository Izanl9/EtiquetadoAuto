@page "/reconocimiento"
@using EtiquetadoAuto.Models
@using Microsoft.Maui.Media
@using Microsoft.JSInterop
@using Android.Gms.Extensions 
@inject IJSRuntime JSRuntime
@using EtiquetadoAuto.Services
@inject DatabaseService DB
@inject EtiquetadoAuto.Services.PdfService GeneradorPdf


<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white text-center">
            <h4><i class="oi oi-camera"></i> Reconocimiento de Albarán</h4>
        </div>
        <div class="card-body text-center">
            <p class="text-muted">Captura una foto del albarán para detectar automáticamente los productos y cantidades.</p>
            
            @if (isProcessing)
            {
                <div class="my-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">Procesando imagen...</p>
                </div>
            }
            else
            {
                <button class="btn btn-lg btn-success w-100 mb-3" @onclick="CapturarAlbaran">
                    <i class="oi oi-camera"></i> Tomar Foto
                </button>
                <div style="margin-top: 20px; padding: 10px; background-color: #f0f0f0; border-radius: 8px;">
                    <h3>Texto Detectado:</h3>
                    <p>@textoDetectado</p>
                </div>
            }

            @if (productosDetectados.Any())
            {
                <hr />
                <div class="d-grid gap-2">
                    <button class="btn btn-lg btn-primary shadow" @onclick="ProcesarTodo">
                        <i class="oi oi-check"></i> IMPRIMIR Y GUARDAR EN INVENTARIO
                    </button>
        
                    <button class="btn btn-outline-danger btn-sm mt-2" @onclick="() => productosDetectados.Clear()">
                        Cancelar
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<Producto> productosDetectados = new();
    private bool isProcessing = false;
    
    // 1. ¡AQUÍ! Declaramos la variable que faltaba
    private string textoDetectado = "Esperando albarán..."; 

    // 2. ¡AQUÍ! Le cambiamos el nombre para que coincida con el botón
    private async Task CapturarAlbaran()
    {
        try
        {
            isProcessing = true; // Activamos tu spinner de carga
            textoDetectado = "Abriendo cámara...";
            StateHasChanged(); 

            var photo = await MediaPicker.CapturePhotoAsync();
            if (photo == null)
            {
                textoDetectado = "Foto cancelada.";
                isProcessing = false;
                return;
            }

            textoDetectado = "Procesando imagen con IA...";
            StateHasChanged(); 

            #if ANDROID
            var javaFile = new Java.IO.File(photo.FullPath);
            var imageUri = Android.Net.Uri.FromFile(javaFile);
            var image = Xamarin.Google.MLKit.Vision.Common.InputImage.FromFilePath(Android.App.Application.Context, imageUri);
            var options = Xamarin.Google.MLKit.Vision.Text.Latin.TextRecognizerOptions.DefaultOptions;
            var recognizer = Xamarin.Google.MLKit.Vision.Text.TextRecognition.GetClient(options);
            
            var result = await recognizer.Process(image);
            var visionText = (Xamarin.Google.MLKit.Vision.Text.Text)result;
            
            textoDetectado = visionText.GetText();
            
            if (string.IsNullOrWhiteSpace(textoDetectado))
            {
                textoDetectado = "No se detectó ningún texto claro en la imagen.";
            }
            else
            {
                // 3. ¡AQUÍ! Conectamos el texto leído con tu método para extraer los productos
                ProcesarTexto(textoDetectado);
            }
            #endif
        }
        catch (Exception ex)
        {
            textoDetectado = $"ERROR: {ex.Message}";
        }
        finally
        {
            isProcessing = false; // Apagamos el spinner
            StateHasChanged();
        }
    }

    private void ProcesarTextoDetectado(string texto)
{
    var lineas = texto.Split('\n');
    productosDetectados.Clear();

    foreach (var linea in lineas)
    {
        if (string.IsNullOrWhiteSpace(linea)) continue;

        // Intentamos extraer: [Número/Cantidad] [Nombre Producto]
        // Esta Regex busca un número y luego el resto de la frase
        var match = System.Text.RegularExpressions.Regex.Match(linea, @"(\d+)\s+(.+)");

        if (match.Success)
        {
            int cant = int.Parse(match.Groups[1].Value);
            string nombre = match.Groups[2].Value.Trim();

            if (!string.IsNullOrEmpty(nombre) && nombre.Length > 2)
            {
                productosDetectados.Add(new Producto { 
                    Nombre = nombre, 
                    Cantidad = cant, 
                    Codigo = "GEN-" + DateTime.Now.ToString("mmss") 
                });
            }
        }
        else if (linea.Length > 3) // Si no hay número, pero hay una palabra larga (como Humidificador)
        {
            productosDetectados.Add(new Producto { 
                Nombre = linea.Trim(), 
                Cantidad = 1, 
                Codigo = "OCR-" + DateTime.Now.ToString("mmss") 
            });
        }
    }
}

    private async Task ProcesarTodo()
    {
        if (!productosDetectados.Any()) return;

        try
        {
            isProcessing = true;
            StateHasChanged();

            // 1. GUARDAR EN BASE DE DATOS
            foreach (var prod in productosDetectados)
            {
                await DB.GuardarProducto(prod);
            }

            // 2. GENERAR E IMPRIMIR PDF (Etiquetas individuales)
            string rutaArchivo = GeneradorPdf.GenerarEtiquetas(productosDetectados);
            
            await Launcher.Default.OpenAsync(new OpenFileRequest
            {
                Title = "Imprimir Etiquetas",
                File = new ReadOnlyFile(rutaArchivo)
            });

            // 3. LIMPIAR TODO PARA EL SIGUIENTE
            productosDetectados.Clear();
            textoDetectado = "Albarán procesado con éxito.";
            
            await JSRuntime.InvokeVoidAsync("alert", "Guardado e impresión enviada.");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }
}