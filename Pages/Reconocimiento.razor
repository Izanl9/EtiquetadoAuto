@page "/reconocimiento"
@using EtiquetadoAuto.Models
@using EtiquetadoAuto.Services
@using Microsoft.Maui.Media
@using Microsoft.JSInterop
@using System.Threading.Tasks
@inject IJSRuntime JSRuntime
@inject DatabaseService DB
@inject PdfService GeneradorPdf

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white text-center">
            <h4 class="mb-0"><i class="oi oi-camera"></i> Reconocimiento de Albarán</h4>
        </div>
        <div class="card-body text-center">
            <p class="text-muted">Captura una foto del albarán para detectar automáticamente los productos y cantidades.</p>
            
            @if (isProcessing)
            {
                <div class="my-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">@estadoMensaje</p>
                </div>
            }
            else
            {
                <button class="btn btn-lg btn-success w-100 mb-3 shadow" @onclick="CapturarAlbaran">
                    <i class="oi oi-camera"></i> TOMAR FOTO
                </button>
            }

            @if (productosDetectados.Any())
            {
                <hr />
                <h5 class="text-start mb-3">Productos Identificados:</h5>
                <ul class="list-group mb-3 shadow-sm">
                    @foreach (var prod in productosDetectados)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div class="text-start">
                                <strong>@prod.Nombre</strong><br />
                                <small class="text-muted">Ref: @prod.Codigo</small>
                            </div>
                            <span class="badge bg-primary rounded-pill fs-6">x @prod.Cantidad</span>
                        </li>
                    }
                </ul>

                <div class="d-grid gap-2">
                    <button class="btn btn-lg btn-primary shadow" @onclick="ProcesarTodo">
                        <i class="oi oi-print"></i> IMPRIMIR Y GUARDAR
                    </button>
                    <button class="btn btn-outline-danger btn-sm" @onclick="LimpiarEscaneo">
                        Cancelar y Borrar
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    // Clase auxiliar para agrupar texto por su posición en el papel
    public class InfoLinea 
    {
        public string Texto { get; set; } = "";
        public int Y { get; set; }
    }

    private List<Producto> productosDetectados = new();
    private bool isProcessing = false;
    private string estadoMensaje = "Procesando...";

    private async Task CapturarAlbaran()
    {
        try
        {
            isProcessing = true;
            estadoMensaje = "Abriendo cámara...";
            StateHasChanged(); 

            var photo = await MediaPicker.CapturePhotoAsync();
            if (photo == null) return;

            estadoMensaje = "Analizando imagen...";
            StateHasChanged(); 

            #if ANDROID
            var javaFile = new Java.IO.File(photo.FullPath);
            var imageUri = Android.Net.Uri.FromFile(javaFile);
            var image = Xamarin.Google.MLKit.Vision.Common.InputImage.FromFilePath(Android.App.Application.Context, imageUri);
            
            var options = Xamarin.Google.MLKit.Vision.Text.Latin.TextRecognizerOptions.DefaultOptions;
            var recognizer = Xamarin.Google.MLKit.Vision.Text.TextRecognition.GetClient(options);
            
            // Usamos TaskCompletionSource para esperar la respuesta de la API de Android
            var tcs = new TaskCompletionSource<object>();
            
            recognizer.Process(image)
                .AddOnSuccessListener(new OnSuccessImplementation(tcs))
                .AddOnFailureListener(new OnFailureImplementation(tcs));

            var resultObj = await tcs.Task;
            var visionText = (Xamarin.Google.MLKit.Vision.Text.Text)resultObj;
            
            ProcesarTextoEspacial(visionText);
            #else
            await JSRuntime.InvokeVoidAsync("alert", "El OCR requiere un dispositivo Android.");
            #endif
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error: " + ex.Message);
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    #if ANDROID
    private void ProcesarTextoEspacial(Xamarin.Google.MLKit.Vision.Text.Text visionText)
    {
        productosDetectados.Clear();
        var todasLasLineas = new List<InfoLinea>();

        // 1. Extraemos todas las líneas con su coordenada Y (altura)
        foreach (var block in visionText.TextBlocks)
        {
            foreach (var line in block.Lines)
            {
                todasLasLineas.Add(new InfoLinea { 
                    Texto = line.Text.Trim(), 
                    Y = line.BoundingBox.CenterY() 
                });
            }
        }

        if (!todasLasLineas.Any()) return;

        // 2. Ordenamos por altura para procesar de arriba a abajo
        var lineasOrdenadas = todasLasLineas.OrderBy(l => l.Y).ToList();

        // 3. Agrupamos en "filas" reales si la diferencia de altura es < 25 píxeles
        var filas = new List<List<InfoLinea>>();
        var filaActual = new List<InfoLinea> { lineasOrdenadas[0] };

        for (int i = 1; i < lineasOrdenadas.Count; i++)
        {
            if (Math.Abs(lineasOrdenadas[i].Y - lineasOrdenadas[i-1].Y) < 25)
            {
                filaActual.Add(lineasOrdenadas[i]);
            }
            else
            {
                filas.Add(new List<InfoLinea>(filaActual));
                filaActual = new List<InfoLinea> { lineasOrdenadas[i] };
            }
        }
        filas.Add(filaActual);

        // 4. Analizamos cada fila detectada
        foreach (var fila in filas)
        {
            string textoFilaUnido = string.Join(" ", fila.Select(f => f.Texto));
            string minus = textoFilaUnido.ToLower();

            // --- FILTRO DE BASURA AGRESIVO ---
            if (minus.Contains("albara") || minus.Contains("serie") || minus.Contains("comanda") || 
                minus.Contains("nom") || minus.Contains("telefon") || minus.Contains("telf") ||
                minus.Contains("direccio") || minus.Contains("fecha") || minus.Contains("quantitat") ||
                minus.Contains("descripci") || minus.Contains("www.") || minus.Contains("@") || 
                minus.Contains("izan") || minus.Contains("lecina") || minus.Contains("carrer") ||
                minus.Contains("nro") || minus.Contains("edit.org"))
            {
                continue;
            }

            // Detectar números de teléfono o series (8+ dígitos ignorando espacios)
            string sinEspacios = textoFilaUnido.Replace(" ", "");
            if (System.Text.RegularExpressions.Regex.IsMatch(sinEspacios, "\\d{8,}")) continue;

            // Ignorar números sueltos grandes (como el número de albarán 87530)
            if (System.Text.RegularExpressions.Regex.IsMatch(textoFilaUnido.Trim(), "^\\d{4,7}$")) continue;

            int cantidadEncontrada = 0;
            string nombreProducto = "";

            foreach (var item in fila)
            {
                // ¿Es un número pequeño de 1 a 3 cifras? (Probablemente la cantidad)
                if (System.Text.RegularExpressions.Regex.IsMatch(item.Texto.Trim(), "^\\d{1,3}$"))
                {
                    cantidadEncontrada = int.Parse(item.Texto.Trim());
                }
                else if (item.Texto.Length > 3)
                {
                    // Limpiamos el texto pero mantenemos letras, números y símbolos de marca
                    string limpio = System.Text.RegularExpressions.Regex.Replace(item.Texto, "[^a-zA-Z0-9áéíóúÁÉÍÓÚñÑ\\s\\.\\-®]", "").Trim();
                    if (!string.IsNullOrEmpty(limpio))
                    {
                        nombreProducto += (string.IsNullOrEmpty(nombreProducto) ? "" : " ") + limpio;
                    }
                }
            }

            // --- VALIDACIÓN FINAL DEL PRODUCTO ---
            if (!string.IsNullOrWhiteSpace(nombreProducto) && nombreProducto.Length > 5)
            {
                productosDetectados.Add(new Producto {
                    Nombre = nombreProducto,
                    Cantidad = cantidadEncontrada > 0 ? cantidadEncontrada : 1,
                    Codigo = "OCR-" + DateTime.Now.ToString("mmss")
                });
            }
        }
        StateHasChanged();
    }
    #endif

    private async Task ProcesarTodo()
    {
        try
        {
            isProcessing = true;
            estadoMensaje = "Guardando e imprimiendo...";
            StateHasChanged();

            foreach (var prod in productosDetectados)
            {
                await DB.GuardarProducto(prod);
            }

            string rutaArchivo = GeneradorPdf.GenerarEtiquetas(productosDetectados);
            
            await Launcher.Default.OpenAsync(new OpenFileRequest
            {
                Title = "Etiquetas de Albarán",
                File = new ReadOnlyFile(rutaArchivo)
            });

            LimpiarEscaneo();
            await JSRuntime.InvokeVoidAsync("alert", "Proceso completado con éxito.");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error al procesar: " + ex.Message);
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private void LimpiarEscaneo()
    {
        productosDetectados.Clear();
    }

#if ANDROID
    // Implementaciones de los Listeners de Google ML Kit para Android
    public class OnSuccessImplementation : Java.Lang.Object, Android.Gms.Tasks.IOnSuccessListener
    {
        private readonly TaskCompletionSource<object> _tcs;
        public OnSuccessImplementation(TaskCompletionSource<object> tcs) => _tcs = tcs;
        public void OnSuccess(Java.Lang.Object result) => _tcs.SetResult(result);
    }

    public class OnFailureImplementation : Java.Lang.Object, Android.Gms.Tasks.IOnFailureListener
    {
        private readonly TaskCompletionSource<object> _tcs;
        public OnFailureImplementation(TaskCompletionSource<object> tcs) => _tcs = tcs;
        public void OnFailure(Java.Lang.Exception e) => _tcs.SetException(e);
    }
#endif
}