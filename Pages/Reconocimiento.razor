@page "/reconocimiento"
@using EtiquetadoAuto.Models
@using EtiquetadoAuto.Services
@using Microsoft.Maui.Media
@using Microsoft.JSInterop
@using System.Threading.Tasks
@inject IJSRuntime JSRuntime
@inject DatabaseService DB
@inject PdfService GeneradorPdf

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white text-center py-3">
            <h4 class="mb-0"><i class="oi oi-camera"></i> Escaneo de Albarán</h4>
        </div>
        <div class="card-body text-center">
            <p class="text-secondary">Capture el albarán. Se filtrarán automáticamente webs, teléfonos y direcciones.</p>
            
            @if (isProcessing)
            {
                <div class="my-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-3 fw-bold text-primary">@estadoMensaje</p>
                </div>
            }
            else
            {
                <button class="btn btn-success btn-lg w-100 py-3 shadow-sm mb-4" @onclick="CapturarAlbaran">
                    <i class="oi oi-camera"></i> ESCANEAR AHORA
                </button>
            }

            @if (productosDetectados.Any())
            {
                <div class="text-start">
                    <h5 class="mb-3">Material Identificado:</h5>
                    <div class="list-group shadow-sm mb-4">
                        @foreach (var prod in productosDetectados)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="d-block fw-bold">@prod.Nombre</span>
                                    <small class="text-muted">Ref: @prod.Codigo</small>
                                </div>
                                <span class="badge bg-primary rounded-pill px-3 py-2">Cant: @prod.Cantidad</span>
                            </div>
                        }
                    </div>
                    
                    <div class="d-grid gap-2">
                        <button class="btn btn-primary btn-lg shadow" @onclick="ProcesarTodo">
                            <i class="oi oi-check"></i> CONFIRMAR E IMPRIMIR
                        </button>
                        <button class="btn btn-light btn-sm text-danger" @onclick="LimpiarEscaneo">
                            Borrar todo y repetir
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    public class InfoLinea 
    {
        public string Texto { get; set; } = "";
        public int Y { get; set; }
        public int X { get; set; }
    }

    private List<Producto> productosDetectados = new();
    private bool isProcessing = false;
    private string estadoMensaje = "";

    private async Task CapturarAlbaran()
    {
        try
        {
            isProcessing = true;
            estadoMensaje = "Iniciando cámara...";
            StateHasChanged(); 

            var photo = await MediaPicker.CapturePhotoAsync();
            if (photo == null) return;

            estadoMensaje = "Analizando texto...";
            StateHasChanged(); 

            #if ANDROID
            var javaFile = new Java.IO.File(photo.FullPath);
            var imageUri = Android.Net.Uri.FromFile(javaFile);
            var image = Xamarin.Google.MLKit.Vision.Common.InputImage.FromFilePath(Android.App.Application.Context, imageUri);
            
            var options = Xamarin.Google.MLKit.Vision.Text.Latin.TextRecognizerOptions.DefaultOptions;
            var recognizer = Xamarin.Google.MLKit.Vision.Text.TextRecognition.GetClient(options);
            
            var tcs = new TaskCompletionSource<object>();
            recognizer.Process(image)
                .AddOnSuccessListener(new OnSuccessImplementation(tcs))
                .AddOnFailureListener(new OnFailureImplementation(tcs));

            var resultObj = await tcs.Task;
            var visionText = (Xamarin.Google.MLKit.Vision.Text.Text)resultObj;
            
            ProcesarTextoMejorado(visionText);
            #else
            await JSRuntime.InvokeVoidAsync("alert", "Funcionalidad disponible en Android.");
            #endif
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error: " + ex.Message);
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    #if ANDROID
    private void ProcesarTextoMejorado(Xamarin.Google.MLKit.Vision.Text.Text visionText)
    {
        productosDetectados.Clear();
        var todasLasLineas = new List<InfoLinea>();

        foreach (var block in visionText.TextBlocks)
        {
            foreach (var line in block.Lines)
            {
                todasLasLineas.Add(new InfoLinea { 
                    Texto = line.Text.Trim(), 
                    Y = line.BoundingBox.CenterY(),
                    X = line.BoundingBox.Left
                });
            }
        }

        if (!todasLasLineas.Any()) return;

        // 1. AGRUPACIÓN FLEXIBLE POR ALTURA (Tolera hasta 40px de torcedura en la foto)
        var ordenadas = todasLasLineas.OrderBy(l => l.Y).ToList();
        var filas = new List<List<InfoLinea>>();
        
        var filaActual = new List<InfoLinea> { ordenadas[0] };
        int yReferencia = ordenadas[0].Y;

        for (int i = 1; i < ordenadas.Count; i++)
        {
            if (Math.Abs(ordenadas[i].Y - yReferencia) < 40) 
            {
                filaActual.Add(ordenadas[i]);
            }
            else
            {
                filas.Add(new List<InfoLinea>(filaActual));
                filaActual = new List<InfoLinea> { ordenadas[i] };
                yReferencia = ordenadas[i].Y;
            }
        }
        filas.Add(filaActual);

        foreach (var fila in filas)
        {
            // Unimos los textos de la fila para aplicar filtros
            string textoFila = string.Join(" ", fila.OrderBy(f => f.X).Select(f => f.Texto));
            
            string minus = textoFila.ToLower()
                .Replace("à", "a").Replace("á", "a").Replace("è", "e").Replace("é", "e")
                .Replace("í", "i").Replace("ò", "o").Replace("ó", "o").Replace("ú", "u");

            // --- FILTRO DE CABECERAS ---
            // IMPORTANTE: Bloqueamos "numero de serie", pero NO la palabra "serie" sola.
            if (minus.Contains("albara") || minus.Contains("seditesa") || minus.Contains("sintesis") ||
                minus.Contains("www") || minus.Contains("@") || minus.Contains(".org") || 
                minus.Contains(".com") || minus.Contains("izan") || minus.Contains("lecina") || 
                minus.Contains("carrer") || minus.Contains("carer") || minus.Contains("telf") ||
                minus.Contains("telefon") || minus.Contains("fecha") || minus.Contains("data") || 
                minus.Contains("quantitat") || minus.Contains("descripci") || minus.Contains("nro") || 
                minus.Contains("comanda") || minus.Contains("fictici") || minus.Contains("numero de serie") ||
                minus.Contains("numero de srie"))
            {
                continue;
            }

            // --- FILTRO DE TELÉFONOS Y NÚMEROS LARGOS ---
            // Destruimos TODOS los espacios en blanco antes de comprobar
            string sinEspacios = System.Text.RegularExpressions.Regex.Replace(textoFila, @"\s+", "");
            if (System.Text.RegularExpressions.Regex.IsMatch(sinEspacios, @"\d{8,}")) continue; // Adiós 666004412 y 878787878787
            if (System.Text.RegularExpressions.Regex.IsMatch(sinEspacios, @"^\d{4,7}$")) continue; // Adiós número de Albarán 87530

            int cant = 0;
            string nombre = "";

            // 2. EXTRACCIÓN DE CANTIDAD Y NOMBRE
            foreach (var item in fila.OrderBy(f => f.X))
            {
                string t = item.Texto.Trim();
                
                // Si la cajita tiene solo 1 a 3 números, es la cantidad
                if (System.Text.RegularExpressions.Regex.IsMatch(t, @"^\d{1,3}$"))
                {
                    cant = int.Parse(t);
                }
                else if (t.Length > 3)
                {
                    nombre += (string.IsNullOrEmpty(nombre) ? "" : " ") + t;
                }
            }

            // Limpiamos la basura tipográfica del nombre pero mantenemos lo importante
            nombre = System.Text.RegularExpressions.Regex.Replace(nombre, @"[^a-zA-Z0-9áéíóúÁÉÍÓÚñÑ\s\.\-®]", "").Trim();

            // Salvavidas: Por si el OCR leyó "3 Purgadores" todo junto en un solo bloque
            if (cant == 0)
            {
                var matchInicio = System.Text.RegularExpressions.Regex.Match(nombre, @"^(\d{1,3})\s+(.+)");
                if (matchInicio.Success)
                {
                    cant = int.Parse(matchInicio.Groups[1].Value);
                    nombre = matchInicio.Groups[2].Value.Trim();
                }
            }

            // Validación final: El nombre debe tener al menos 8 letras para considerarse producto válido
            if (!string.IsNullOrWhiteSpace(nombre) && nombre.Length > 7)
            {
                productosDetectados.Add(new Producto {
                    Nombre = nombre,
                    Cantidad = cant > 0 ? cant : 1, // Si tras todo no hay cantidad, ponemos 1
                    Codigo = "OCR-" + DateTime.Now.ToString("mmssfff")
                });
            }
        }
    }
    #endif

    private async Task ProcesarTodo()
    {
        try
        {
            isProcessing = true;
            estadoMensaje = "Guardando...";
            StateHasChanged();

            foreach (var prod in productosDetectados)
                await DB.GuardarProducto(prod);

            string path = GeneradorPdf.GenerarEtiquetas(productosDetectados);
            await Launcher.Default.OpenAsync(new OpenFileRequest {
                Title = "PDF de Etiquetas",
                File = new ReadOnlyFile(path)
            });

            LimpiarEscaneo();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error: " + ex.Message);
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private void LimpiarEscaneo() => productosDetectados.Clear();

#if ANDROID
    public class OnSuccessImplementation : Java.Lang.Object, Android.Gms.Tasks.IOnSuccessListener
    {
        private readonly TaskCompletionSource<object> _tcs;
        public OnSuccessImplementation(TaskCompletionSource<object> tcs) => _tcs = tcs;
        public void OnSuccess(Java.Lang.Object result) => _tcs.SetResult(result);
    }

    public class OnFailureImplementation : Java.Lang.Object, Android.Gms.Tasks.IOnFailureListener
    {
        private readonly TaskCompletionSource<object> _tcs;
        public OnFailureImplementation(TaskCompletionSource<object> tcs) => _tcs = tcs;
        public void OnFailure(Java.Lang.Exception e) => _tcs.SetException(e);
    }
#endif
}