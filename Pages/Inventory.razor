@page "/inventory"
@using EtiquetadoAuto.Models
@using EtiquetadoAuto.Services
@inject DatabaseService DB

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white text-center">
            <h4><i class="oi oi-list"></i> Inventario Actual</h4>
        </div>
        <div class="card-body">
            
            @if (productos == null)
            {
                <div class="text-center my-4">
                    <div class="spinner-border text-success" role="status"></div>
                    <p class="mt-2">Cargando base de datos...</p>
                </div>
            }
            else if (!productos.Any())
            {
                <div class="alert alert-info text-center">
                    El inventario está vacío. ¡Ve a Reconocimiento y escanea tu primer albarán!
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Código</th>
                                <th>Nombre</th>
                                <th>Cantidad</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var producto in productos)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">@producto.Codigo</span></td>
                                    <td>@producto.Nombre</td>
                                    <td><strong>@producto.Cantidad</strong></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

        </div>
    </div>
</div>

@code {
    private List<Producto> productos = new();

    // Este método se dispara cada vez que el componente se carga en el DOM
    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    // Opcional: Si notas que al volver atrás no refresca, 
    // puedes usar este evento que detecta cuando la página vuelve a ser el foco
    private async Task CargarDatos()
    {
        productos = await DB.ObtenerTodos();
        StateHasChanged(); // Forzamos a Blazor a redibujar la UI
    }
}