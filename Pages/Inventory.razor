@page "/inventory"
@namespace EtiquetadoAuto.Pages
@using EtiquetadoAuto.Models
@using EtiquetadoAuto.Services
@inject StockService StockService

<div class="container mt-3">
    <h4 class="mb-4"> Inventario (Nube)</h4>

    @if (productos == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Sincronizando con Firebase...</p>
        </div>
    }
    else
    {
        <div class="list-group">
            @foreach (var prod in productos)
            {
                <div class="list-group-item d-flex justify-content-between align-items-center shadow-sm mb-2">
                    <div>
                        <h6 class="mb-0 text-primary">@prod.Id</h6>
                        <small class="text-muted">Último cambio: @prod.LastUpdate.ToShortTimeString()</small>
                    </div>
                    <div class="text-end">
                        <span class="badge bg-dark fs-6">Stock: @prod.Quantity</span>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
private List<Product> productos = new(); 
    private string errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            productos = await StockService.GetProductsAsync();
            if (productos == null) productos = new List<Product>();
        }
        catch (Exception ex) 
        {
            errorMessage = "Error de conexión: " + ex.Message;
            productos = new List<Product>(); // Evita que el foreach de error
        }
    }
}

@if (productos == null) {
    <p><em>Cargando inventario...</em></p>
} else if (!string.IsNullOrEmpty(errorMessage)) {
    <p style="color:red">@errorMessage</p>
} else {
    }
