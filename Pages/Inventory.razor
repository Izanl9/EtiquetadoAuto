@page "/inventory"
@using EtiquetadoAuto.Models
@using EtiquetadoAuto.Services
@using Microsoft.AspNetCore.Components.Routing
@implements IDisposable
@inject DatabaseService DB

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="oi oi-list"></i> Inventario</h4>
            <span class="badge bg-light text-dark">@productos.Count Items</span>
        </div>
        <div class="card-body">
            @if (productos == null)
            {
                <div class="text-center"><div class="spinner-border text-success"></div></div>
            }
            else if (!productos.Any())
            {
                <div class="alert alert-info">No hay productos guardados.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Nombre</th>
                                <th>Código</th>
                                <th>Cant.</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in productos)
                            {
                                <tr>
                                    <td>@p.Nombre</td>
                                    <td><small class="text-muted">@p.Codigo</small></td>
                                    <td><span class="badge bg-primary">@p.Cantidad</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<Producto> productos = new();

    protected override async Task OnInitializedAsync()
    {
        // Nos suscribimos al evento para refrescar cuando se guarde algo nuevo
        DB.OnDataChanged += RefrescarVista;
        await CargarDatos();
    }

    protected override async Task OnParametersSetAsync()
    {
        await CargarDatos();
    }

    private async void RefrescarVista()
    {
        // Usamos InvokeAsync porque el evento viene de otro hilo (la DB)
        await InvokeAsync(async () => {
            await CargarDatos();
            StateHasChanged();
        });
    }

    private async Task CargarDatos()
    {
        productos = await DB.ObtenerTodos();
    }

    public void Dispose()
    {
        // Limpiamos el evento para evitar fugas de memoria
        DB.OnDataChanged -= RefrescarVista;
    }
}